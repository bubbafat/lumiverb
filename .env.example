# Copy to .env and fill in values.
# Secrets go in .env.local (gitignored), not here.
#
# Generate API_SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"

CONTROL_PLANE_DATABASE_URL=postgresql+psycopg2://app:secret@127.0.0.1:5432/control_plane
TENANT_DATABASE_URL_TEMPLATE=postgresql+psycopg2://app:secret@127.0.0.1:5432/{tenant_id}

QUICKWIT_URL=http://localhost:7280
QUICKWIT_ENABLED=true
QUICKWIT_FALLBACK_TO_POSTGRES=true

STORAGE_PROVIDER=local
DATA_DIR=./data

API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=
ADMIN_KEY=

MOONDREAM_STATION_ENDPOINT=http://localhost:2020/v1

# OpenAI-compatible vision API (for non-Moondream models)
VISION_API_URL=http://localhost:1234/v1

WORKER_IDLE_POLL_SECONDS=5
WORKER_LEASE_MINUTES=10

EXIFTOOL_PATH=exiftool
SHARPNESS_MAX_VARIANCE=1000.0

APP_ENV=development
LOG_LEVEL=WARNING
